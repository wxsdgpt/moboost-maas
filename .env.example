# ╔══════════════════════════════════════════════════════════════════════╗
# ║  Moboost MAAS — Environment Variables                              ║
# ║  Copy to .env.local:  cp .env.example .env.local                   ║
# ║  See docs/ENV_GUIDE.md for how to obtain each key                  ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ─── OpenRouter (AI Model Gateway) ─────────────────────────────────────
# Get your key: https://openrouter.ai/keys
# Free tier: ~$1 credit. Add credits at https://openrouter.ai/credits
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model IDs — change to any model available on OpenRouter
IMAGE_MODEL=google/gemini-3-pro-image-preview
VIDEO_MODEL=google/veo-3.1
EVAL_MODEL=anthropic/claude-sonnet-4-6

# ─── Supabase (Database + Storage) ─────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Storage bucket name (must exist in Supabase Storage, set to public)
SUPABASE_STORAGE_BUCKET=creatives

# ─── Clerk (Authentication) ────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ─── Admin Auth ────────────────────────────────────────────────────────
# Random secret for admin API token signing. Generate with:
#   openssl rand -hex 32
ADMIN_TOKEN_SECRET=your-random-secret-here

# ─── Data Directory ────────────────────────────────────────────────────
# Local directory for markdown data files (market reports, templates)
DATA_DIR=./data

# ─── Auth Bypass (QA / Testing ONLY) ───────────────────────────────────
# Set to 1 to disable ALL auth checks. Shows red warning banner.
# NEVER enable in production!
AUTH_BYPASS=0
NEXT_PUBLIC_AUTH_BYPASS=0

# ─── Collaborator API Webhook ──────────────────────────────────────────
# Optional: POST events to external system on asset creation
# Signature uses HMAC-SHA256 in X-Moboost-Signature header
COLLAB_WEBHOOK_URL=
COLLAB_WEBHOOK_SECRET=

# ─── Ad-Localization Backend ───────────────────────────────────────────
# URL where the FastAPI backend is running
# Docker: http://backend:8000  |  Local: http://localhost:8000
ADLOC_SERVICE_URL=http://localhost:8000

# Shared secret for Next.js → FastAPI proxy authentication
# Must match ADLOC_SERVICE_TOKEN in backend .env
ADLOC_SERVICE_TOKEN=dev-service-token

# ═══════════════════════════════════════════════════════════════════════
# BACKEND-SPECIFIC VARIABLES (prefix: ADLOC_)
# Set these in services/ad-localization/backend/.env
# or in the root .env (backend reads from parent directories)
# ═══════════════════════════════════════════════════════════════════════

# ADLOC_APP_ENV=dev                    # dev | test | staging | prod
# ADLOC_LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
# ADLOC_DATABASE_URL=postgresql+psycopg://postgres:dev123@localhost:5432/ad_localization
# ADLOC_JWT_SECRET=dev-secret-change-me
# ADLOC_SERVICE_TOKEN=dev-service-token

# Storage (local for dev, s3 for prod)
# ADLOC_STORAGE_DRIVER=local           # local | s3
# ADLOC_STORAGE_LOCAL_ROOT=./storage
# ADLOC_S3_BUCKET=
# ADLOC_S3_REGION=
# ADLOC_S3_ACCESS_KEY=
# ADLOC_S3_SECRET_KEY=
# ADLOC_S3_ENDPOINT_URL=

# AI providers (optional — OpenRouter is the primary path)
# ADLOC_OPENROUTER_API_KEY=            # Same key as frontend, or separate
# ADLOC_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# ADLOC_ANTHROPIC_API_KEY=
# ADLOC_OPENAI_API_KEY=
# ADLOC_GOOGLE_API_KEY=
