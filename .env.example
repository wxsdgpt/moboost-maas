# Moboost AI MAAS — Environment Variables
# Copy this file to .env.local and fill in your real keys:
#   cp .env.example .env.local

# OpenRouter API Key (get from https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model IDs
IMAGE_MODEL=google/gemini-3-pro-image-preview
VIDEO_MODEL=google/veo-3.1
EVAL_MODEL=anthropic/claude-sonnet-4-6

# Data directory
DATA_DIR=./data

# ─── Supabase ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Bucket for creatives + localizations (must exist + be public).
# Defaults to "creatives" if unset.
SUPABASE_STORAGE_BUCKET=creatives

# ─── Clerk ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ─── Admin auth ─────────────────────────────────────────────────────────
ADMIN_TOKEN_SECRET=

# ─── v1.0.2 Auth bypass (QA / testing only) ─────────────────────────────
# Set to 1 to disable ALL auth checks (Clerk + admin + onboarding).
# Shows a red banner across every page while enabled. Do NOT ship to prod.
AUTH_BYPASS=0
NEXT_PUBLIC_AUTH_BYPASS=0

# ─── Collaborator API webhook ───────────────────────────────────────────
# When set, asset/landing create+regenerate events POST here with an
# HMAC-SHA256 signature in the X-Moboost-Signature header.
COLLAB_WEBHOOK_URL=
COLLAB_WEBHOOK_SECRET=
