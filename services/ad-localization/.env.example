# Ad Localization Service — Environment Variables
# All prefixed with ADLOC_ to avoid collision with parent project

# Core
ADLOC_APP_ENV=dev
ADLOC_APP_NAME=ad-localization
ADLOC_LOG_LEVEL=INFO

# Database (shared PostgreSQL, isolated schema)
ADLOC_DATABASE_URL=postgresql+psycopg://postgres:dev123@localhost:5432/ad_localization

# Auth — service-to-service token from moboost-maas
ADLOC_JWT_SECRET=change-me-in-production
ADLOC_JWT_ALGORITHM=HS256
ADLOC_JWT_ACCESS_TTL_MINUTES=60

# Storage (shared S3 with moboost-maas, namespaced prefix)
ADLOC_STORAGE_DRIVER=local
ADLOC_STORAGE_LOCAL_ROOT=./storage
# ADLOC_S3_BUCKET=
# ADLOC_S3_REGION=
# ADLOC_S3_ACCESS_KEY=
# ADLOC_S3_SECRET_KEY=
# ADLOC_S3_ENDPOINT_URL=

# AI Providers (independent from moboost-maas)
# ADLOC_ANTHROPIC_API_KEY=
# ADLOC_OPENAI_API_KEY=
# ADLOC_GOOGLE_API_KEY=
# ADLOC_GOOGLE_PROJECT_ID=

# OpenRouter (preferred gateway)
# ADLOC_OPENROUTER_API_KEY=
# ADLOC_OPENROUTER_MODEL=
# ADLOC_OPENROUTER_VISION_MODEL=
# ADLOC_OPENROUTER_IMAGE_EDIT_MODEL=
# ADLOC_OPENROUTER_VIDEO_MODEL=

# CORS — include moboost-maas origin
ADLOC_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
